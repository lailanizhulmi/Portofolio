%%EOF

      --sage-soft:#E2E7DF;
      --line:rgba(33,24,21,.16);
      --champagne:#D9C2AE;
      --white:#FFF9F1;
      --shadow:0 22px 60px rgba(33,24,21,.13);
      --soft-shadow:0 12px 32px rgba(33,24,21,.10);
      --radius-lg:34px;
      --radius-md:22px;
      --radius-sm:14px;
    }
    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      background:var(--canvas) url('assets/paper_texture.jpg') repeat;
      color:var(--ink);
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif;
      line-height:1.55;
      letter-spacing:-.02em;
    }
    a{color:inherit;text-decoration:none}
    img{display:block;max-width:100%;height:auto}
    .shell{width:min(1180px, calc(100% - 48px));margin:0 auto}
    .grain{position:fixed;inset:0;pointer-events:none;opacity:.25;mix-blend-mode:multiply;background-image:radial-gradient(rgba(90,3,3,.07) 1px, transparent 1px);background-size:22px 22px;z-index:999}
    .nav{
      position:sticky;top:0;z-index:100;background:rgba(247,237,225,.82);backdrop-filter: blur(18px);
      border-bottom:1px solid var(--line);
    }
    .nav-inner{height:74px;display:flex;align-items:center;justify-content:space-between;gap:24px}
    .brand{display:flex;align-items:center;gap:12px;font-weight:750;letter-spacing:.04em;text-transform:uppercase;font-size:13px}
    .brand-mark{width:36px;height:36px;border-radius:50%;background:var(--burgundy);color:var(--canvas);display:grid;place-items:center;font-family:Georgia,serif;font-weight:800;letter-spacing:-.08em;font-size:17px;box-shadow: inset 0 0 0 1px rgba(255,255,255,.25)}
    .nav-links{display:flex;align-items:center;gap:20px;font-size:13px;text-transform:uppercase;letter-spacing:.08em;color:rgba(33,24,21,.72);font-weight:650}
    .nav-links a{position:relative;padding:8px 0}
    .nav-links a:after{content:"";position:absolute;left:0;bottom:3px;width:0;height:1px;background:var(--burgundy);transition:.25s}
    .nav-links a:hover:after{width:100%}
    .nav-cta{background:var(--deep-green);color:var(--canvas);padding:10px 16px;border-radius:999px;font-weight:750;box-shadow:var(--soft-shadow)}
    .hero{padding:62px 0 72px;position:relative;overflow:hidden}
    .hero:before{content:"";position:absolute;right:-180px;top:80px;width:480px;height:480px;background:radial-gradient(circle, rgba(170,106,88,.25), transparent 70%);filter:blur(5px)}
    .hero-grid{display:grid;grid-template-columns:1.08fr .92fr;gap:44px;align-items:stretch}
    .eyebrow{font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:var(--burgundy);font-weight:800;margin-bottom:18px}
    h1{font-family:Georgia, 'Times New Roman', serif;font-weight:500;line-height:.92;margin:0;font-size:clamp(72px, 9vw, 138px);letter-spacing:-.075em;color:var(--ink)}
    h1 span{display:block;color:var(--burgundy)}
    .title-line{margin:22px 0 0;font-size:clamp(22px,3vw,40px);line-height:1.06;font-family:Georgia, 'Times New Roman', serif;letter-spacing:-.05em;max-width:740px;color:var(--deep-green)}
    .hero-copy{font-size:18px;max-width:700px;color:rgba(33,24,21,.78);margin:18px 0 0}
    .hero-ctas{display:flex;gap:12px;flex-wrap:wrap;margin-top:30px}
    .btn{display:inline-flex;align-items:center;justify-content:center;gap:10px;min-height:46px;padding:12px 18px;border-radius:999px;border:1px solid var(--line);font-weight:750;letter-spacing:-.01em;box-shadow:0 10px 24px rgba(33,24,21,.07);background:rgba(255,249,241,.65)}
    .btn.primary{background:var(--burgundy);border-color:var(--burgundy);color:var(--canvas)}
    .btn.green{background:var(--deep-green);border-color:var(--deep-green);color:var(--canvas)}
    .hero-meta{display:flex;gap:10px;flex-wrap:wrap;margin-top:24px;color:var(--muted);font-size:14px}
    .chip{border:1px solid var(--line);background:rgba(255,249,241,.48);border-radius:999px;padding:8px 12px;display:inline-flex;align-items:center;gap:8px}
    .hero-visual{position:relative;min-height:680px;border-radius:var(--radius-lg);overflow:hidden;background:var(--champagne);box-shadow:var(--shadow)}
    .hero-visual .portrait{width:100%;height:100%;object-fit:cover;object-position:center 19%;filter:saturate(.96) contrast(1.02)}
    .hero-visual:after{content:"";position:absolute;inset:0;background:linear-gradient(180deg, transparent 45%, rgba(33,24,21,.28));}
    .floating-card{position:absolute;left:22px;right:22px;bottom:22px;z-index:2;background:rgba(247,237,225,.86);backdrop-filter:blur(16px);border:1px solid rgba(255,255,255,.38);border-radius:24px;padding:18px;box-shadow:0 20px 50px rgba(33,24,21,.18)}
    .floating-card p{margin:0;color:var(--muted);font-size:14px}
    .floating-card strong{display:block;color:var(--ink);font-size:18px;margin-bottom:3px}
    .impact-strip{display:grid;grid-template-columns:repeat(6,1fr);gap:12px;margin-top:36px}
    .stat{border:1px solid var(--line);border-radius:22px;background:rgba(255,249,241,.55);padding:18px;min-height:130px;display:flex;flex-direction:column;justify-content:space-between;box-shadow:0 10px 30px rgba(33,24,21,.05)}
    .stat .num{font-family:Georgia,serif;font-size:34px;line-height:1;color:var(--burgundy);letter-spacing:-.05em}
    .stat .label{font-size:13px;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);font-weight:750;margin-top:12px;line-height:1.3}
    section{padding:86px 0;border-top:1px solid var(--line)}
    .section-head{display:flex;justify-content:space-between;gap:28px;align-items:flex-end;margin-bottom:34px}
    .kicker{font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:var(--terracotta);font-weight:850;margin-bottom:10px}
    h2{font-family:Georgia,'Times New Roman',serif;font-size:clamp(44px,5vw,76px);line-height:.96;letter-spacing:-.07em;font-weight:500;margin:0;color:var(--ink)}
    .section-note{max-width:430px;color:var(--muted);font-size:16px;margin:0}
    .about-grid{display:grid;grid-template-columns:1fr 1.05fr;gap:34px;align-items:stretch}
    .quote-card{background:var(--burgundy);color:var(--canvas);border-radius:var(--radius-lg);padding:34px;min-height:420px;display:flex;flex-direction:column;justify-content:space-between;box-shadow:var(--shadow);position:relative;overflow:hidden}
    .quote-card:before{content:"";position:absolute;right:-80px;bottom:-80px;width:260px;height:260px;border-radius:50%;background:rgba(247,237,225,.08)}
    .quote-card .big{font-family:Georgia,serif;font-size:46px;line-height:1.02;letter-spacing:-.055em;margin:0;position:relative;z-index:1}
    .quote-card .small{color:rgba(247,237,225,.75);max-width:440px;margin:24px 0 0;position:relative;z-index:1}
    .system-card{background:rgba(255,249,241,.62);border:1px solid var(--line);border-radius:var(--radius-lg);padding:28px;box-shadow:var(--soft-shadow)}
    .system-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px}
    .step{background:rgba(247,237,225,.75);border:1px solid var(--line);border-radius:20px;padding:18px;min-height:142px}
    .step b{display:flex;align-items:center;gap:12px;font-size:15px;letter-spacing:-.01em;color:var(--deep-green)}
    .step span{width:30px;height:30px;border-radius:50%;background:var(--sage-soft);display:grid;place-items:center;color:var(--burgundy);font-weight:850;font-size:12px;flex:0 0 auto}
    .step p{margin:12px 0 0;color:var(--muted);font-size:14px;line-height:1.45}
    .dashboard{display:grid;grid-template-columns:1.1fr .9fr;gap:24px}
    .dashboard-panel{background:var(--deep-green);color:var(--canvas);border-radius:var(--radius-lg);padding:32px;box-shadow:var(--shadow);position:relative;overflow:hidden}
    .dashboard-panel:before{content:"";position:absolute;inset:auto -120px -160px auto;width:380px;height:380px;border-radius:50%;background:rgba(247,237,225,.08)}
    .dashboard-panel h3, .visual-proof h3, .capabilities h3, .contact-card h3{font-family:Georgia,serif;font-size:36px;line-height:1;letter-spacing:-.055em;margin:0 0 18px}
    .metric-buckets{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;margin-top:22px;position:relative;z-index:1}
    .bucket{border:1px solid rgba(247,237,225,.22);background:rgba(255,255,255,.06);border-radius:22px;padding:18px;min-height:164px}
    .bucket .num{font-family:Georgia,serif;font-size:40px;line-height:1;letter-spacing:-.04em;margin-bottom:8px}
    .bucket b{font-size:14px;text-transform:uppercase;letter-spacing:.08em}
    .bucket p{margin:8px 0 0;color:rgba(247,237,225,.72);font-size:13px;line-height:1.45}
    .visual-proof{background:rgba(255,249,241,.62);border:1px solid var(--line);border-radius:var(--radius-lg);padding:22px;box-shadow:var(--soft-shadow)}
    .proof-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:16px}
    .proof-grid img{border-radius:18px;aspect-ratio:1.28/1;object-fit:cover;border:1px solid var(--line)}
    .work-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:14px}
    .work-card{background:rgba(255,249,241,.7);border:1px solid var(--line);border-radius:26px;overflow:hidden;box-shadow:0 12px 30px rgba(33,24,21,.07);display:flex;flex-direction:column;min-height:430px}
    .work-card .media{height:160px;background:var(--champagne);position:relative;overflow:hidden}
    .work-card .media img{width:100%;height:100%;object-fit:cover}
    .work-card .body{padding:18px;display:flex;flex-direction:column;gap:10px;flex:1}
    .work-card h3{font-size:20px;letter-spacing:-.04em;line-height:1.08;margin:0;color:var(--burgundy)}
    .work-card p{margin:0;color:var(--muted);font-size:13px;line-height:1.45}
    .tags{display:flex;gap:6px;flex-wrap:wrap;margin-top:auto}
    .tag{font-size:10px;text-transform:uppercase;letter-spacing:.09em;font-weight:850;border:1px solid var(--line);border-radius:999px;padding:5px 7px;color:var(--deep-green);background:rgba(226,231,223,.55)}
    .case-layout{display:grid;grid-template-columns:1fr 1fr;gap:24px;align-items:start}
    .case-card{border-radius:var(--radius-lg);background:rgba(255,249,241,.72);border:1px solid var(--line);overflow:hidden;box-shadow:var(--soft-shadow)}
    .case-card img{width:100%;aspect-ratio:1.72/1;object-fit:cover;border-bottom:1px solid var(--line)}
    .case-body{padding:28px}
    .case-body h3{font-size:32px;font-family:Georgia,serif;line-height:1;letter-spacing:-.05em;margin:0 0 14px;color:var(--burgundy)}
    .case-body p{color:var(--muted);margin:0 0 18px}
    .case-list{display:grid;gap:10px;margin:0;padding:0;list-style:none}
    .case-list li{display:grid;grid-template-columns:118px 1fr;gap:12px;padding:10px 0;border-top:1px solid var(--line);font-size:14px}
    .case-list b{color:var(--deep-green);text-transform:uppercase;letter-spacing:.08em;font-size:11px}
    .experience-grid{display:grid;grid-template-columns:.95fr 1.05fr;gap:24px}
    .timeline{background:rgba(255,249,241,.62);border:1px solid var(--line);border-radius:var(--radius-lg);padding:28px;box-shadow:var(--soft-shadow)}
    .time-item{display:grid;grid-template-columns:112px 1fr;gap:20px;padding:20px 0;border-top:1px solid var(--line)}
    .time-item:first-of-type{border-top:0;padding-top:0}
    .year{color:var(--burgundy);font-weight:850;font-size:13px;letter-spacing:.08em;text-transform:uppercase}
    .time-item h3{margin:0 0 6px;font-size:21px;line-height:1.1;letter-spacing:-.035em}
    .time-item p{margin:0;color:var(--muted);font-size:14px}
    .capabilities{background:var(--ink);color:var(--canvas);border-radius:var(--radius-lg);padding:28px;box-shadow:var(--shadow)}
    .cap-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:20px}
    .cap{background:rgba(255,255,255,.06);border:1px solid rgba(247,237,225,.15);border-radius:18px;padding:16px;min-height:126px}
    .cap b{font-size:14px;color:var(--champagne)}
    .cap p{color:rgba(247,237,225,.72);font-size:13px;line-height:1.45;margin:8px 0 0}
    .presence{display:grid;grid-template-columns:1.2fr .8fr;gap:24px;align-items:stretch}
    .presence .image-stack{display:grid;grid-template-columns:1fr 1fr;gap:14px}
    .presence img{width:100%;height:100%;object-fit:cover;border-radius:28px;border:1px solid var(--line);box-shadow:var(--soft-shadow)}
    .presence-card{background:var(--burgundy);color:var(--canvas);border-radius:var(--radius-lg);padding:32px;box-shadow:var(--shadow);display:flex;flex-direction:column;justify-content:space-between}
    .presence-card h3{font-family:Georgia,serif;font-size:42px;line-height:1;letter-spacing:-.06em;margin:0}
    .presence-card p{color:rgba(247,237,225,.78);font-size:15px}
    .contact-wrap{display:grid;grid-template-columns:1fr 1fr;gap:24px;align-items:stretch}
